# low-poly tank example (Wavefront OBJ)
mtllib tank.mtl

o tank
# Hull vertices (box)
v -1.2 0.0 -2.0
v  1.2 0.0 -2.0
v  1.2 0.0  2.0
v -1.2 0.0  2.0
v -1.2 0.9 -2.0
v  1.2 0.9 -2.0
v  1.2 0.9  2.0
v -1.2 0.9  2.0

# Turret vertices (box)
v -0.65 0.9 -0.75
v  0.65 0.9 -0.75
v  0.65 0.9  0.75
v -0.65 0.9  0.75
v -0.65 1.5 -0.75
v  0.65 1.5 -0.75
v  0.65 1.5  0.75
v -0.65 1.5  0.75

# Barrel vertices (thin box)
v -0.12 1.12 -2.9
v  0.12 1.12 -2.9
v  0.12 1.30 -2.9
v -0.12 1.30 -2.9
v -0.12 1.12 -0.75
v  0.12 1.12 -0.75
v  0.12 1.30 -0.75
v -0.12 1.30 -0.75

# UVs
vt 0.00 0.00
vt 1.00 0.00
vt 1.00 1.00
vt 0.00 1.00

usemtl tank_hull
# Hull faces
f 1/1 2/2 3/3 4/4
f 5/1 8/2 7/3 6/4
f 1/1 5/2 6/3 2/4
f 2/1 6/2 7/3 3/4
f 3/1 7/2 8/3 4/4
f 4/1 8/2 5/3 1/4

usemtl tank_turret
# Turret faces
f 9/1 10/2 11/3 12/4
f 13/1 16/2 15/3 14/4
f 9/1 13/2 14/3 10/4
f 10/1 14/2 15/3 11/4
f 11/1 15/2 16/3 12/4
f 12/1 16/2 13/3 9/4

usemtl tank_barrel
# Barrel faces
f 17/1 18/2 19/3 20/4
f 21/1 24/2 23/3 22/4
f 17/1 21/2 22/3 18/4
f 18/1 22/2 23/3 19/4
f 19/1 23/2 24/3 20/4
f 20/1 24/2 21/3 17/4
