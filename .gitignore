# Build artifacts
/build/
/target/
/dist/

# Runtime save data written by the engine during test runs
/save/

# Golden test actual outputs (generated during test runs; only expected/ is committed)
/tests/rust/golden/actual/

# Session and planning artifacts
/work/

# Generated tool output logs (regenerated by tools/gen_all_docs.py and audit scripts)
/logs/

# Local research and draft docs
/ideas/competition/

# Root diagnostics and runtime logs
/cargo_check_err.txt
/clippy_out.txt
/clippy_output.txt

# Python bytecode (all subdirectories)
**/__pycache__/
**/*.pyc
**/*.pyo

# VS Code extension — build outputs and generated files
extensions/vscode/node_modules/
extensions/vscode/dist/
extensions/vscode/src/generated/
extensions/vscode/*.vsix

# Transient test output logs and scratch directories
extensions/vscode/.vscode-test/
