{
  "name": "lurek2d-vscode",
  "displayName": "Lurek2D",
  "description": "AI-first IDE support for Lurek2D game engine",
  "version": "0.1.0",
  "publisher": "lurek2d",
  "icon": "media/luna-logo.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/main.lua",
    "workspaceContains:Cargo.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lurek2d.runExample",
        "title": "Lurek2D: Run Example"
      },
      {
        "command": "lurek2d.listExamples",
        "title": "Lurek2D: List Examples"
      },
      {
        "command": "lurek2d.checkBuild",
        "title": "Lurek2D: Check Build"
      },
      {
        "command": "lurek2d.getApiDoc",
        "title": "Lurek2D: Get API Documentation"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  }
}
