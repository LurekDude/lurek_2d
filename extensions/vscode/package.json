    "keybindings": [
      {
        "command": "lurek.runGame",
        "key": "alt+l",
        "when": "editorTextFocus && resourceLangId == lua"
      },
      {
        "command": "lurek.stopGame",
        "key": "shift+alt+l",
        "when": "lurek.gameRunning"
      },
      {
        "command": "lurek.openWiki",
        "key": "f2",
        "when": "editorTextFocus && resourceLangId == lua"
      },
      {
        "command": "lurek.test.all",
        "key": "ctrl+shift+t",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "lurek.runGame",
          "when": "resourceLangId == lua",
          "group": "lurek@1"
        },
        {
          "command": "lurek.openWiki",
          "when": "resourceLangId == lua",
          "group": "lurek@2"
        },
        {
          "command": "lurek.test.generateForFile",
          "when": "resourceLangId == lua",
          "group": "lurek@3"
        }
      ],
      "explorer/context": [
        {
          "command": "lurek.runGame",
          "when": "explorerResourceIsFolder",
          "group": "lurek@1"
        }
      ],
      "view/title": [
        {
          "command": "lurek.assets.refresh",
          "when": "view == lurek.assetExplorer",
          "group": "navigation"
        },
        {
          "command": "lurek.assets.findMissing",
          "when": "view == lurek.assetExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "lurek.assets.insertPath",
          "when": "view == lurek.assetExplorer && viewItem =~ /^assetItem/",
          "group": "lurek@1"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "lurek.sceneLuaEditor",
        "displayName": "Lurek2D Scene Editor",
        "selector": [
          {
            "filenamePattern": "*.scene.lua"
          }
        ],
        "priority": "default"
      }
    ],
    "snippets": [
      {
        "language": "lua",
        "path": "./data/snippets.json"
      }
    ],
    "configuration": {
      "title": "Lurek2D Toolkit",
      "properties": {
        "lurek.lurekPath": {
          "type": "string",
          "default": "",
          "description": "Path to lurek2d executable"
        },
        "lurek.srcDir": {
          "type": "string",
          "default": "",
          "description": "Game source subdirectory"
        },
        "lurek.saveOnRun": {
          "type": "boolean",
          "default": true,
          "description": "Save files before running"
        },
        "lurek.diagnostics.deprecationWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show deprecated API warnings"
        },
        "lurek.diagnostics.commonMistakes": {
          "type": "boolean",
          "default": true,
          "description": "Detect common Lurek2D mistakes"
        },
        "lurek.diagnostics.unusedRequires": {
          "type": "boolean",
          "default": true,
          "description": "Flag unused require statements"
        },
        "lurek.diagnostics.assetValidation": {
          "type": "boolean",
          "default": true,
          "description": "Validate asset file paths"
        },
        "lurek.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name hints"
        },
        "lurek.test.testDir": {
          "type": "string",
          "default": "tests",
          "description": "Test directory path"
        },
        "lurek.test.luaTestDir": {
          "type": "string",
          "default": "tests/lua",
          "description": "Lua test directory"
        },
        "lurek.cag.installOnScaffold": {
          "type": "boolean",
          "default": true,
          "description": "Auto-install AI config on scaffold"
        },
        "lurek.package.outputDir": {
          "type": "string",
          "default": "dist",
          "description": "Build output directory"
        },
        "lurek.debugBridge.port": {
          "type": "number",
          "default": 19740,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Debug bridge TCP port"
        },
        "lurek.debugBridge.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-connect on debug run"
        },
        "lurek.luaVersion": {
          "type": "string",
          "enum": [
            "luajit",
            "5.4"
          ],
          "default": "luajit",
          "description": "Lua runtime version for IntelliSense (LuaJIT or Lua 5.4)"
        },
        "lurek.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name hints inline"
        },
        "lurek.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Lurek2D-specific diagnostics"
        },
        "lurek.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Lua code formatting"
        },
        "lurek.intellisense.luaStdlib": {
          "type": "boolean",
          "default": true,
          "description": "Include Lua standard library in completions"
        },
        "lurek.intellisense.luajitHints": {
          "type": "boolean",
          "default": true,
          "description": "Show LuaJIT performance optimization hints (table alloc in hot path, string concat in loops, etc.)"
        },
        "lurek.intellisense.patternLibrary": {
          "type": "boolean",
          "default": true,
          "description": "Offer pattern library snippets (state machine, object pool, class, event bus, etc.)"
        },
        "lurek.intellisense.keyNameCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Show key name completions inside input API string arguments (lurek.input.isDown, lurek.keypressed)"
        },
        "lurek.intellisense.easingHoverChart": {
          "type": "boolean",
          "default": true,
          "description": "Show easing curve ASCII chart when hovering over easing function name strings"
        },
        "lurek.intellisense.typeInference": {
          "type": "boolean",
          "default": true,
          "description": "Track return types from lurek.* factory functions and enable method completion on instances"
        },
        "lurek.intellisense.globalWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Warn on implicit global variable writes (prefer local declarations)"
        },
        "lurek.intellisense.unusedAssets": {
          "type": "boolean",
          "default": false,
          "description": "Detect asset files in assets/ that are never referenced in Lua code (may be slow on large projects)"
        },
        "lurek.intellisense.classPatternDetection": {
          "type": "boolean",
          "default": true,
          "description": "Detect OOP class patterns (setmetatable, __index) and enable method completion on class instances"
        },
        "lurek.debugger.port": {
          "type": "number",
          "default": 8172,
          "description": "Default TCP port for Lurek2D debug communication"
        }
      }
    },
    "debuggers": [
      {
