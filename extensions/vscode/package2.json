{
  "name": "luna-toolkit",
  "displayName": "Luna Toolkit",
  "description": "The official VS Code extension for Lurek2D game engine development. Lua IntelliSense, 100+ lurek.* completions, live diagnostics, debug bridge, system monitor, test runner, visual editors, and full project tooling.",
  "version": "0.9.0",
  "publisher": "lurek2d",
  "icon": "media/luna-logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RandomBladeDude/lurek2d"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "lua",
    "game",
    "game engine",
    "2d",
    "lurek2d",
    "game development",
    "pixel art",
    "tilemap"
  ],
  "activationEvents": [
    "workspaceContains:**/main.lua",
    "workspaceContains:Cargo.toml",
    "onLanguage:lua"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "luna-sidebar",
          "title": "Luna Toolkit",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "luna-sidebar": [
        {
          "id": "lurek.projectTools",
          "name": "Project"
        },
        {
          "id": "lurek.devTools",
          "name": "Dev Tools"
        },
        {
          "id": "lurek.assetExplorer",
          "name": "Assets"
        },
        {
          "id": "lurek.aiCopilot",
          "name": "AI & Copilot"
        }
      ]
    },
    "viewsWelcome": [
