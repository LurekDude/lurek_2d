{
    "version": "0.2.0",
    // ─────────────────────────────────────────────────────────────────────────
    // Debugger: lldb (CodeLLDB — works on Windows/Linux/macOS via the
    // vadimcn.vscode-lldb extension).
    //
    // These two launch configs build the binary and launch it without a game
    // directory (splash screen mode).  To run a specific example game, use
    // the Tasks menu (Terminal → Run Task → "Run Debug: Pick Example" or
    // "Run Release: Pick Example").
    //
    // Prerequisite extensions (see .vscode/extensions.json):
    //   rust-lang.rust-analyzer  — Rust language server + cargo integration
    //   vadimcn.vscode-lldb      — provides the lldb debug adapter
    // ─────────────────────────────────────────────────────────────────────────
    "configurations": [
        // ─── 🐛 DEBUG ─────────────────────────────────────────────────────────
        // [profile.dev]: opt-level=0, full DWARF debug symbols (debug=2), no optimizations.
        // Fastest possible compile. Binary is large and slow to run — use for debugging only.
        {
            "type": "lldb",
            "request": "launch",
            "name": "🐛 Build Debug (no game)",
            "cargo": {
                "args": ["build", "--bin=lurek2d"],
                "filter": { "name": "lurek2d", "kind": "bin" }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [],
            "console": "integratedTerminal"
        },
        // ─── 🚀 RELEASE ───────────────────────────────────────────────────────
        // [profile.release]: opt-level=3, fat LTO, stripped, panic=abort.
        // ~20 MB raw binary. Use dist.ps1 to apply UPX and ship at ~5 MB.
        {
            "type": "lldb",
            "request": "launch",
            "name": "🚀 Build Release (no game)",
            "cargo": {
                "args": ["build", "--bin=lurek2d", "--release"],
                "filter": { "name": "lurek2d", "kind": "bin" }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [],
            "console": "integratedTerminal"
        },
        // ─── ⚡ RUN DEBUG (from source) ───────────────────────────────────────
        // Builds with [profile.dev] (opt-level=0, full DWARF) then launches.
        {
            "type": "lldb",
            "request": "launch",
            "name": "⚡ Run Debug Splash (cargo run)",
            "cargo": {
                "args": ["run", "--bin", "lurek2d"]
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        // ─── ⚡ RUN RELEASE (from source) ────────────────────────────────────
        // Builds with [profile.release] (opt-level=3, LTO, stripped) then launches.
        {
            "type": "lldb",
            "request": "launch",
            "name": "⚡ Run Release Splash (cargo run)",
            "cargo": {
                "args": ["run", "--bin", "lurek2d", "--release"]
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}
